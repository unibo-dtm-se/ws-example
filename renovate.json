{
  "extends": [
    "config:base",
    ":rebaseStalePrs",
    ":semanticCommits"
  ],
  "assignees": [
    "gciatto"
  ],
  "automerge": true,
  "dependencyDashboard": true,
  "git-submodules": {
    "enabled": true
  },
  "includeForks": true,
  "ignorePaths": [
    ".python-version"
  ],
  "packageRules": [
    {
      "description": "Updates to GitHub Actions should be tagged as 'ci'",
      "matchPaths": [
        ".github/workflows/*.yml",
        ".github/workflows/*.yaml"
      ],
      "semanticCommitType": "ci"
    },
    {
      "description": "Frontend npm updates should keep a frontend scope",
      "matchManagers": [
        "npm"
      ],
      "matchPaths": [
        "frontend/package.json",
        "frontend/package-lock.json"
      ],
      "semanticCommitScope": "frontend"
    },
    {
      "description": "Backend Python dependency updates should keep a backend scope",
      "matchManagers": [
        "pep621",
        "poetry",
        "pip_requirements"
      ],
      "matchPaths": [
        "backend/pyproject.toml",
        "backend/poetry.lock",
        "backend/requirements.txt"
      ],
      "semanticCommitScope": "backend"
    }
  ],
  "prConcurrentLimit": 25,
  "prHourlyLimit": 0,
  "separateMajorMinor": true,
  "separateMinorPatch": true,
  "separateMultipleMajor": true
}